<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>New Release</title>
    <style type='text/css'>
      body,
      html {
        margin: 0;
        padding: 0;
        background-color: #f6f8fa;
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial,
          sans-serif;
      }
      .wrapper {
        width: 100%;
        min-height: 100vh;
        background-color: #f6f8fa;
        padding: 40px 20px;
        box-sizing: border-box;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 8px;
        border: 1px solid #d0d7de;
        padding: 40px;
        box-shadow: 0 3px 6px rgba(140, 149, 159, 0.15);
      }
      h2 {
        color: #24292f;
        margin-top: 0;
        font-size: 24px;
      }
      p {
        color: #57606a;
        font-size: 16px;
        line-height: 1.6;
      }
      .version-tag {
        color: #0969da;
        font-size: 18px;
        font-weight: 600;
      }
      .btn-wrapper {
        text-align: center;
        margin: 32px 0;
      }
      .btn {
        display: inline-block;
        background-color: #0969da;
        color: #ffffff;
        padding: 12px 24px;
        text-decoration: none;
        border-radius: 6px;
        font-weight: 600;
        font-size: 16px;
        border: 1px solid #0969da;
      }
      .footer {
        margin-top: 40px;
        border-top: 1px solid #d0d7de;
        padding-top: 20px;
        text-align: center;
      }
      .footer p {
        color: #8c959f;
        font-size: 12px;
        margin: 0;
      }
      .unsubscribe-link {
        color: #57606a;
        font-size: 12px;
        text-decoration: underline;
        margin-top: 8px;
        display: inline-block;
      }
      @media only screen and (max-width: 600px) {
        .container {
          padding: 20px;
        }
        h2 {
          font-size: 20px;
        }
        p {
          font-size: 15px;
        }
      }
    </style>
  </head>
  <body>
    <div class='wrapper'>
      <div class='container'>
        <h2>New Release in {{repoName}} 🎉</h2>

        <p>
          Great news! Version
          <span class='version-tag'>{{tag}}</span>
          has just been published.
        </p>

        <div class='btn-wrapper'>
          <a href='{{releaseUrl}}' class='btn'>View Release on GitHub</a>
        </div>

        <div class='footer'>
          <p>
            You are receiving this because you subscribed to
            {{repoName}}
            notifications.
          </p>
          <a href='{{unsubscribeUrl}}' class='unsubscribe-link'>
            Unsubscribe from this repository
          </a>
        </div>
      </div>
    </div>
  </body>
</html>