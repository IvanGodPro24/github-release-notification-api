<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Confirm Subscription</title>
    <style type='text/css'>
      body,
      html {
        margin: 0;
        padding: 0;
        background-color: #f6f8fa;
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial,
          sans-serif;
      }
      .wrapper {
        width: 100%;
        min-height: 100vh;
        background-color: #f6f8fa;
        padding: 40px 20px;
        box-sizing: border-box;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 8px;
        border: 1px solid #d0d7de;
        padding: 40px;
        box-shadow: 0 3px 6px rgba(140, 149, 159, 0.15);
      }
      h2 {
        color: #24292f;
        margin-top: 0;
        font-size: 24px;
      }
      p {
        color: #57606a;
        font-size: 16px;
        line-height: 1.6;
        margin-bottom: 24px;
      }
      .highlight {
        color: #24292f;
        font-weight: 600;
      }
      .btn-wrapper {
        text-align: center;
        margin: 32px 0;
      }
      .btn {
        display: inline-block;
        background-color: #2da44e;
        color: #ffffff;
        padding: 12px 24px;
        text-decoration: none;
        border-radius: 6px;
        font-weight: 600;
        font-size: 16px;
        border: 1px solid #2c974b;
      }
      .footer {
        color: #57606a;
        font-size: 14px;
        margin-top: 32px;
        border-top: 1px solid #d0d7de;
        padding-top: 20px;
      }
      @media only screen and (max-width: 600px) {
        .container {
          padding: 20px;
        }
        h2 {
          font-size: 20px;
        }
        p {
          font-size: 15px;
        }
      }
    </style>
  </head>
  <body>
    <div class='wrapper'>
      <div class='container'>
        <h2>Welcome to GitHub Notifier!</h2>

        <p>
          You requested to subscribe to release notifications for the repository
          <span class='highlight'>{{repoName}}</span>. Please confirm your
          subscription by clicking the button below.
        </p>

        <div class='btn-wrapper'>
          <a href='{{confirmUrl}}' class='btn'>Confirm Subscription</a>
        </div>

        <p class='footer'>
          If you didn't request this subscription, you can safely ignore this
          email.
        </p>
      </div>
    </div>
  </body>
</html>