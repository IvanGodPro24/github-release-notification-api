{
  "name": "github-release-notification-api",
  "version": "1.0.0",
  "description": "API for subscribing to GitHub repository release notifications via email",
  "main": "dist/src/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "start:worker": "node dist/src/queue/email.worker.js",
    "dev": "tsx watch src/index.ts",
    "worker": "tsx src/queue/email.worker.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "generate": "prisma generate",
    "postinstall": "prisma generate",
    "prebuild": "npm run build-docs",
    "predev": "npm run build-docs",
    "build-docs": "redocly bundle docs/openapi.yaml --ext json -o docs/swagger.json",
    "preview-docs": "redocly preview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IvanGodPro24/github-release-notification-api.git"
  },
  "keywords": [],
  "author": "Ivan Nepotachev <vanyanep@gmail.com>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/IvanGodPro24/github-release-notification-api/issues"
  },
  "homepage": "https://github.com/IvanGodPro24/github-release-notification-api#readme",
  "dependencies": {
    "@bull-board/api": "^6.21.0",
    "@bull-board/express": "^6.21.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "axios": "^1.14.0",
    "bullmq": "^5.73.4",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "handlebars": "^4.7.9",
    "http-errors": "^2.0.1",
    "ioredis": "^5.10.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@redocly/cli": "^2.26.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^30.3.0",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
